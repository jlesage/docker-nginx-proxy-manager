#!/bin/sh

# This command reads the `DISABLE_IPV6` env var and will either enable
# or disable ipv6 in all nginx configs based on this setting.

is_mounted() {
	awk -v p="$1" '$5 == p { found=1 } END { exit !found }' /proc/self/mountinfo
}

# Lowercase
DISABLE_IPV6=$(echo "${DISABLE_IPV6:-}" | tr '[:upper:]' '[:lower:]')

FOLDER=$1
if [ "$FOLDER" = "" ]; then
	echo "$0 requires a absolute folder path as the first argument!"
	exit 1
fi

FILES=$(find "$FOLDER" -type f -name "*.conf")
SED_REGEX=

if is-bool-val-true "${DISABLE_IPV6:-0}"; then
	# IPV6 is disabled
	echo "Disabling IPV6 in hosts in: $1"
	SED_REGEX='s/^([^#]*)listen \[::\]/\1#listen [::]/g'
else
	# IPV6 is enabled
	echo "Enabling IPV6 in hosts in: $1"
	SED_REGEX='s/^(\s*)#listen \[::\]/\1listen [::]/g'
fi

for FILE in $FILES
do
	echo "- ${FILE}"
	TMPFILE="${FILE}.tmp"

	if is_mounted "${FILE}"; then
		echo "WARNING: skipping ${FILE} — mounted file" >&2
	elif sed -E "$SED_REGEX" "$FILE" > "$TMPFILE" && [ -s "$TMPFILE" ]; then
		mv "$TMPFILE" "$FILE"
	else
		echo "WARNING: skipping ${FILE} — sed produced empty output" >&2
		rm -f "$TMPFILE"
	fi
done
